{
  "id": "faq",
  "label": "FAQ",
  "context": "product",
  "contexts": ["product", "archive"],
  "category": "content",
  "max_instances": 1,
  "allowed_zones": ["product_after_summary", "product_before_related", "product_after_related", "product_before_tabs", "product_after_tabs", "archive_after_loop", "archive_sidebar_bottom"],
  "settings": {
    "title": { "type": "text", "label": "Title", "default": "Frequently asked questions" },
    "items": {
      "type": "repeater",
      "label": "FAQ Items",
      "item_label": "Question",
      "default": [
        { "question": "How fast is shipping?", "answer": "Orders usually ship within 24 hours.", "open_by_default": "0" },
        { "question": "Can I return it?", "answer": "Yes, within 30 days in original condition.", "open_by_default": "0" }
      ],
      "fields": [
        { "id": "question", "type": "text", "label": "Question", "default": "" },
        { "id": "answer", "type": "textarea", "label": "Answer", "default": "" },
        { "id": "open_by_default", "type": "toggle", "label": "Open By Default", "default": "0" }
      ]
    }
  }
}
