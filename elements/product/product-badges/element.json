{
  "id": "product-badges",
  "label": "Product Badges",
  "context": "product",
  "category": "conversion",
  "max_instances": 1,
  "allowed_zones": ["product_before_gallery", "product_after_gallery", "product_before_summary", "product_after_summary"],
  "settings": {
    "show_sale": { "type": "toggle", "label": "Show Sale Badge", "default": "1" },
    "show_featured": { "type": "toggle", "label": "Show Featured Badge", "default": "1" },
    "show_stock": { "type": "toggle", "label": "Show Stock Badge", "default": "1" },
    "show_new": { "type": "toggle", "label": "Show New Badge", "default": "1" },
    "new_days": { "type": "number", "label": "New Badge Days", "default": "14", "min": "1", "max": "90", "step": "1" },
    "sale_label": { "type": "text", "label": "Sale Label", "default": "Sale" },
    "featured_label": { "type": "text", "label": "Featured Label", "default": "Featured" },
    "new_label": { "type": "text", "label": "New Label", "default": "New" },
    "out_of_stock_label": { "type": "text", "label": "Out Of Stock Label", "default": "Out of stock" }
  }
}
